using System;

public class Registro_de_Paciente
{
    static void Main()
    {
        Console.WriteLine ("Escribe el nombre del paciente: ");
        string nombre = Console.ReadLine();
        Console.WriteLine ("Cual es la edad del paciente: ");
        string edad = Console.ReadLine();
        Console.WriteLine("Ingrese el peso del paciente(Kg): ");
        double peso = Convert.ToDouble(Console.ReadLine());
        Console.WriteLine("Ingresa la estatura del paciente(M): ");
        double estatura = Convert.ToDouble(Console.ReadLine());
        Console.WriteLine("Tiene seguro medico (SI/NO): ");
        string seguro = Console.ReadLine();
        double IMC = peso/(estatura*estatura);
        string IMC2 = "";
        if (IMC<18.5)
            {
                IMC2 = ("(Peso bajo)");
            }
        else if ((IMC>18.5) && (IMC<24.9))
            {
                IMC2 = ("(Peso normal)");
            }
        else if ((IMC>24.9) && (IMC<29.9))
            {
                IMC2 = ("(Sobrepeso)");
            }
        else if (IMC>29.9)
            {
                IMC2 = ("(Obesidad)");
            }
        else 
            {
                Console.WriteLine("No puedes ingresar numeros negativos");
            }
        Console.WriteLine ("====MENU====");
        Console.WriteLine ("Nombre = " + nombre);
        Console.WriteLine ("Edad = " + edad);
        Console.WriteLine ("IMC = " + IMC + " " + IMC2);
        Console.WriteLine ("Seguro = " + seguro);
    }
}
